rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety catch-all: deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow read/write access to class_diary so anyone on the webpage can collaborate
    match /class_diary/{entryId} {
      allow read, write: if true;
    }
  }
}
